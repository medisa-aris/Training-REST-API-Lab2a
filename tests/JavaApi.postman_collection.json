      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://{{IP_SERVER}}:{{PORT}}/v1/bookings/1/cancellation",
          "protocol": "http",
          "host": ["{{IP_SERVER}}"],
          "port": "{{PORT}}",
          "path": ["v1", "bookings", "1", "cancellation"]
        }
      },
